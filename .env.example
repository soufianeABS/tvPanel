# =========================
# Global
# =========================
HEADLESS=false
PORT=8080

# HTTP API mode:
# - false = headless
# - true  = visible browser (debug/manual captcha)
API_HEADFUL=false

# =========================
# Common (shared)
# =========================
# Captcha handling:
# - HEADLESS=false: solve captcha manually in visible browser
# - HEADLESS=true: set 2Captcha provider + key for unattended runs
CAPTCHA_PROVIDER=
CAPTCHA_API_KEY=
CAPTCHA_TIMEOUT_MS=180000
CAPTCHA_POLL_MS=5000

# =========================
# Dino use case
# =========================
DINO_USERNAME=abdessamad07
DINO_PASSWORD=Azerty_0

# Optional URL override for response field `url` (must include protocol)
# Example: http://line.playmodx.com
DINO_URL_HOST=

# Add Line form values
# Subscription option on #add_sub: 0=2Y, 1=1Y, 2=6M, 3=3M, 4=1M, 5=1D
DINO_LINE_SUBSCRIPTION=5
# Country ISO code (e.g. MA) or leave empty for Auto
DINO_LINE_COUNTRY=
DINO_LINE_NOTES=

