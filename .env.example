TVPLUS_USERNAME=abdessamad07
TVPLUS_PASSWORD=Azerty_0
HEADLESS=false
# Optional unattended auth (recommended on Fly):
# 1) Preferred: full Playwright storage state JSON from a logged-in session.
TVPLUS_STORAGE_STATE_JSON=
# 2) Alternative: raw Cookie header copied after login (e.g. "PHPSESSID=...; other=...").
TVPLUS_SESSION_COOKIE_HEADER=

# After login: open Add Line page (M3U line user) and submit once.
# Page: https://tvpluspanel.ru/addnew?t=lines
TVPLUS_ADDNEW_URL=https://tvpluspanel.ru/addnew?t=lines
TVPLUS_USERS_LINES_URL=https://tvpluspanel.ru/users?s=lines
TVPLUS_SKIP_ADD_LINE=false

# Subscription option value on #add_sub: 0=2Y, 1=1Y, 2=6M, 3=3M, 4=1M, 5=1D
TVPLUS_LINE_SUBSCRIPTION=5
# Country ISO code (e.g. MA) or leave empty for Auto
TVPLUS_LINE_COUNTRY=
TVPLUS_LINE_NOTES=

TVPLUS_KEEP_OPEN_MS=30000

# HTTP server (Fly / Docker): npm start → server.mjs
PORT=8080
# On Fly the API runs headless by default. Set true only for debugging (captcha still blocks unattended login).
TVPLUS_API_HEADFUL=false
